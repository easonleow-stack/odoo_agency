# ─────────────────────────────────────────────────────────────────
#  Ads On Marketing — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git — add it to .gitignore
# ─────────────────────────────────────────────────────────────────

# Database credentials
DB_USER=odoo
DB_PASSWORD=ChangeThisToAStrongPassword123!

# Your server domain (e.g. crm.adsonmarketing.com.my)
DOMAIN=your-domain.com.my

# Email for SSL certificate registration (Let's Encrypt)
ADMIN_EMAIL=your-email@adsonmarketing.com.my
