<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="about_page" name="About Us">
        <t t-call="website.layout">
            <t t-set="title">About — Ads On Marketing</t>

            <div id="wrap" class="agency-page">

                <!-- Page Hero -->
                <section class="page-hero">
                    <div class="container text-center">
                        <span class="section-tag">About Us</span>
                        <h1 class="page-hero-title">The Team Behind the Magic</h1>
                        <p class="page-hero-desc">
                            A passionate team of marketers, creatives, and strategists based in Kuala Lumpur
                        </p>
                    </div>
                </section>

                <!-- Story Section -->
                <section class="agency-section">
                    <div class="container">
                        <div class="row align-items-center g-5">
                            <div class="col-lg-6">
                                <div class="about-visual">
                                    <div class="about-card-stack">
                                        <div class="about-float-card card-a">
                                            <i class="fa fa-trophy fa-2x text-warning"/>
                                            <div class="mt-2">
                                                <strong>Award-Winning</strong>
                                                <br/><small class="text-muted">Creative Excellence</small>
                                            </div>
                                        </div>
                                        <div class="about-float-card card-b">
                                            <i class="fa fa-users fa-2x text-info"/>
                                            <div class="mt-2">
                                                <strong>6 Specialist Teams</strong>
                                                <br/><small class="text-muted">Full-Service Agency</small>
                                            </div>
                                        </div>
                                        <div class="about-float-card card-c">
                                            <i class="fa fa-globe fa-2x text-success"/>
                                            <div class="mt-2">
                                                <strong>Malaysia-Wide</strong>
                                                <br/><small class="text-muted">Reach &amp; Coverage</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <span class="section-tag">Our Story</span>
                                <h2 class="section-title">Built on Passion, Driven by Results</h2>
                                <p>
                                    Ads On Marketing Sdn Bhd is a full-service digital marketing agency
                                    headquartered in Kuala Lumpur, Malaysia. We specialize in helping
                                    businesses of all sizes — from ambitious startups to established
                                    enterprises — build powerful brands and drive measurable growth.
                                </p>
                                <p>
                                    Our team brings together diverse expertise across creative design,
                                    media buying, social media management, strategic planning, and
                                    on-ground activations. This integrated approach means your campaigns
                                    benefit from a cohesive strategy that spans every touchpoint.
                                </p>
                                <p>
                                    We believe in transparency, data-driven decision making, and building
                                    long-term partnerships with our clients. When you work with us,
                                    you get a team that's genuinely invested in your success.
                                </p>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Values Section -->
                <section class="agency-section bg-light">
                    <div class="container">
                        <div class="section-header text-center">
                            <span class="section-tag">Our Values</span>
                            <h2 class="section-title">What We Stand For</h2>
                        </div>
                        <div class="row g-4 mt-4">
                            <div class="col-lg-3 col-md-6">
                                <div class="value-card text-center">
                                    <div class="value-icon">
                                        <i class="fa fa-diamond"/>
                                    </div>
                                    <h5>Excellence</h5>
                                    <p>We hold ourselves to the highest standards in every deliverable, every campaign, every interaction.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="value-card text-center">
                                    <div class="value-icon">
                                        <i class="fa fa-eye"/>
                                    </div>
                                    <h5>Transparency</h5>
                                    <p>Open communication, honest reporting, and clear expectations — no smoke and mirrors.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="value-card text-center">
                                    <div class="value-icon">
                                        <i class="fa fa-rocket"/>
                                    </div>
                                    <h5>Innovation</h5>
                                    <p>We stay ahead of trends and embrace new technologies to give our clients an edge.</p>
                                </div>
                            </div>
                            <div class="col-lg-3 col-md-6">
                                <div class="value-card text-center">
                                    <div class="value-icon">
                                        <i class="fa fa-heart"/>
                                    </div>
                                    <h5>Partnership</h5>
                                    <p>Your success is our success. We build relationships, not just campaigns.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- Teams -->
                <section class="agency-section">
                    <div class="container">
                        <div class="section-header text-center">
                            <span class="section-tag">Our Teams</span>
                            <h2 class="section-title">Specialist Departments</h2>
                            <p class="section-desc">Each team brings unique expertise to deliver integrated campaigns</p>
                        </div>
                        <div class="row g-4 mt-4">
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-purple">
                                        <i class="fa fa-paint-brush"/>
                                    </div>
                                    <h5>Creative</h5>
                                    <p>Designers, art directors, and copywriters who bring ideas to life visually.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-blue">
                                        <i class="fa fa-bullhorn"/>
                                    </div>
                                    <h5>Media Buying</h5>
                                    <p>Media planners and buyers who maximize your ad spend across all channels.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-pink">
                                        <i class="fa fa-share-alt"/>
                                    </div>
                                    <h5>Social Media</h5>
                                    <p>Content creators and community managers who build engaged audiences.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-green">
                                        <i class="fa fa-lightbulb-o"/>
                                    </div>
                                    <h5>Strategy</h5>
                                    <p>Researchers and strategists who turn data into actionable marketing plans.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-orange">
                                        <i class="fa fa-handshake-o"/>
                                    </div>
                                    <h5>Client Services</h5>
                                    <p>Account managers who keep everything running smoothly and clients happy.</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6">
                                <div class="team-card">
                                    <div class="team-icon bg-gradient-red">
                                        <i class="fa fa-map-marker"/>
                                    </div>
                                    <h5>Field Team</h5>
                                    <p>Event coordinators and activators who create memorable real-world experiences.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>

                <!-- CTA -->
                <section class="agency-cta">
                    <div class="cta-bg-shapes">
                        <div class="shape shape-1"/>
                        <div class="shape shape-2"/>
                    </div>
                    <div class="container position-relative text-center">
                        <h2 class="cta-title">Want to Join Our Team?</h2>
                        <p class="cta-desc">
                            We're always looking for talented people who share our passion.
                        </p>
                        <a href="/contact-us" class="btn btn-white btn-lg">
                            Get In Touch <i class="fa fa-arrow-right ms-2"/>
                        </a>
                    </div>
                </section>

            </div>
        </t>
    </template>

</odoo>
